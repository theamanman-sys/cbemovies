rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users collection
    match /users/{userId} {
      // Authenticated users can query/list (needed for username uniqueness check)
      // Admin list restricted to only return uid and username fields via a dedicated API endpoint instead
      allow list: if false;
      // User can read their own document, admins can read all
      allow get: if request.auth != null && (
        request.auth.uid == userId ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'superadmin']
      );

      // User can create their own data (no role/verified/subscribed fields at creation beyond defaults)
      allow create: if request.auth != null && request.auth.uid == userId
        && request.resource.data.keys().hasOnly(['email','phone','username','firstName','lastName','role','verified','subscribed','subscriptionEnd','subscriptionPlan','createdAt','watchlist','history','settings','lastLogin','superappTokenHash'])
        && request.resource.data.role == 'user'
        && request.resource.data.verified == false
        && request.resource.data.subscribed == false;

      // Users can update only safe fields on their own doc; admins can update anything
      allow update: if request.auth != null && (
        (request.auth.uid == userId &&
         !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role','verified','subscribed','subscriptionEnd','subscriptionPlan'])),
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'superadmin']
      );

      // Only admins can delete users
      allow delete: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'superadmin'];
    }

    // Admins collection - only super admin can manage
    match /admins/{adminId} {
      allow read: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'superadmin';
      allow write: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'superadmin';
    }

    // Payments collection
    match /payments/{paymentId} {
      // Users can read their own payments
      allow read: if request.auth != null && (
        request.auth.uid == get(/databases/$(database)/documents/payments/$(paymentId)).data.userId ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'superadmin']
      );
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      // Only admins can change status to 'verified'; users can update non-status fields
      allow update: if request.auth != null && (
        (request.auth.uid == get(/databases/$(database)/documents/payments/$(paymentId)).data.userId &&
         !request.resource.data.diff(resource.data).affectedKeys().hasAny(['status', 'verifiedAt'])) ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'superadmin']
      );
    }

    // Notifications collection - any authenticated user can create, admins can read/update/delete
    match /notifications/{notificationId} {
      allow create: if request.auth != null;
      allow read, update, delete: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'superadmin'];
    }

    // Settings collection - only super admin
    match /settings/{settingId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'superadmin';
    }

    // Usernames collection - for unique username reservation
    match /usernames/{username} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      // Users can update their own username mapping (uid matches)
      allow update: if request.auth != null &&
        request.resource.data.uid == request.auth.uid;
      allow delete: if request.auth != null &&
        resource.data.uid == request.auth.uid;
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
